#!/usr/bin/env bash
set -u

SOURCE_FILE=$(readlink -f -- "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE_FILE")" && pwd)
UNIX_L2_CP_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
export UNIX_L2_CP_ROOT

# shellcheck disable=SC1091
. "$UNIX_L2_CP_ROOT/lib/common.sh"
# shellcheck disable=SC1091
. "$UNIX_L2_CP_ROOT/lib/config.sh"
# shellcheck disable=SC1091
. "$UNIX_L2_CP_ROOT/lib/i18n.sh"

load_settings
load_server_configs >/dev/null 2>&1 || true

pause_screen() {
  echo
  read -r -p "$(tr_text prompt_enter) " _
}

draw_header() {
  setup_colors
  clear 2>/dev/null || true
  printf '%s\n' "${C_CYAN}========================================${C_RESET}"
  printf '%s\n' "${C_BOLD}${UNIX_L2_CP_NAME}${C_RESET}"
  printf '%s\n' "${C_DIM}${UNIX_L2_CP_AUTHOR} | ${UNIX_L2_CP_SITE}${C_RESET}"
  printf '%s\n' "${C_DIM}Host: $(hostname) | $(date '+%Y-%m-%d %H:%M:%S')${C_RESET}"
  printf '%s\n' "${C_CYAN}========================================${C_RESET}"
  echo
}

confirm_action() {
  local answer
  while true; do
    echo "1) $(tr_text yes)"
    echo "2) $(tr_text no)"
    read -r -p "$(tr_text prompt_confirm): " answer
    case "$answer" in
      1|y|Y|yes|YES|д|Д|да|ДА|т|Т|так|ТАК) return 0 ;;
      2|n|N|no|NO|'') return 1 ;;
      *) echo "$(tr_text wrong_choice)" ;;
    esac
  done
}

choose_server() {
  local answer
  local idx
  local id

  while true; do
    echo >&2
    echo "$(tr_text choose_server):" >&2
    idx=1
    for id in "${UL2CP_SERVER_IDS[@]}"; do
      printf '%s) %s\n' "$idx" "$(server_label "$id")" >&2
      idx=$((idx + 1))
    done
    printf '0) %s\n' "$(tr_text back)" >&2
    read -r -p "$(tr_text prompt_choose): " answer

    case "$answer" in
      0|'') return 1 ;;
    esac

    idx=1
    for id in "${UL2CP_SERVER_IDS[@]}"; do
      if [ "$answer" = "$idx" ]; then
        printf '%s\n' "$id"
        return 0
      fi
      idx=$((idx + 1))
    done
    echo "$(tr_text wrong_choice)" >&2
  done
}

choose_role_group() {
  local answer
  while true; do
    echo >&2
    echo "$(tr_text choose_component):" >&2
    echo "1) $(tr_text login)" >&2
    echo "2) $(tr_text game)" >&2
    echo "3) $(tr_text both)" >&2
    echo "0) $(tr_text back)" >&2
    read -r -p "$(tr_text prompt_choose): " answer
    case "$answer" in
      1) printf '%s\n' "login"; return 0 ;;
      2) printf '%s\n' "game"; return 0 ;;
      3) printf '%s\n' "both"; return 0 ;;
      0|'') return 1 ;;
      *) echo "$(tr_text wrong_choice)" >&2 ;;
    esac
  done
}

choose_single_role() {
  local answer
  while true; do
    echo >&2
    echo "$(tr_text choose_component):" >&2
    echo "1) $(tr_text login)" >&2
    echo "2) $(tr_text game)" >&2
    echo "0) $(tr_text back)" >&2
    read -r -p "$(tr_text prompt_choose): " answer
    case "$answer" in
      1) printf '%s\n' "login"; return 0 ;;
      2) printf '%s\n' "game"; return 0 ;;
      0|'') return 1 ;;
      *) echo "$(tr_text wrong_choice)" >&2 ;;
    esac
  done
}

choose_language() {
  local answer
  while true; do
    draw_header
    echo "$(tr_text choose_language):"
    echo "1) Русский"
    echo "2) English"
    echo "3) Українська"
    echo "0) $(tr_text back)"
    read -r -p "$(tr_text prompt_choose): " answer
    case "$answer" in
      1) UNIX_L2_CP_LANG="ru"; return 0 ;;
      2) UNIX_L2_CP_LANG="en"; return 0 ;;
      3) UNIX_L2_CP_LANG="uk"; return 0 ;;
      0|'') return 0 ;;
      *) echo "$(tr_text wrong_choice)"; pause_screen ;;
    esac
  done
}

show_about() {
  draw_header
  echo "$(tr_text about_title)"
  echo "$(tr_text about_lang)"
  echo "$(tr_text about_cfg)"
  echo
  echo "Website: $UNIX_L2_CP_SITE"
  echo "Version: $UNIX_L2_CP_VERSION"
  echo "$UNIX_L2_CP_COPYRIGHT"
  pause_screen
}

run_status() {
  draw_header
  "$UNIX_L2_CP_ROOT/bin/l2ctl" status
  pause_screen
}

run_full() {
  draw_header
  "$UNIX_L2_CP_ROOT/bin/l2ctl" full
  pause_screen
}

run_doctor() {
  draw_header
  "$UNIX_L2_CP_ROOT/bin/l2doctor"
  pause_screen
}

run_action() {
  local action
  local server
  local role

  action="$1"
  server=$(choose_server) || return 0
  role=$(choose_role_group) || return 0

  draw_header
  echo "Action    : $action"
  echo "Server    : $(server_label "$server")"
  echo "Component : $role"
  echo
  case "$action" in
    stop|restart) printf '%s\n\n' "$(tr_text warn_live)" ;;
  esac

  if ! confirm_action; then
    return 0
  fi

  draw_header
  "$UNIX_L2_CP_ROOT/bin/l2ctl" "$action" "$server" "$role"
  echo
  "$UNIX_L2_CP_ROOT/bin/l2ctl" status
  pause_screen
}

run_logs() {
  local mode
  local server
  local role
  local lines

  mode="$1"
  server=$(choose_server) || return 0
  role=$(choose_single_role) || return 0
  read -r -p "$(tr_text prompt_lines) [40]: " lines
  lines="${lines:-40}"

  draw_header
  if [ "$mode" = "follow" ]; then
    printf '%s\n\n' "$(tr_text follow_hint)"
    "$UNIX_L2_CP_ROOT/bin/l2ctl" follow "$server" "$role" "$lines"
  else
    "$UNIX_L2_CP_ROOT/bin/l2ctl" logs "$server" "$role" "$lines"
  fi
  pause_screen
}

while true; do
  draw_header
  echo "1) $(tr_text menu_status)"
  echo "2) $(tr_text menu_full)"
  echo "3) $(tr_text menu_start)"
  echo "4) $(tr_text menu_stop)"
  echo "5) $(tr_text menu_restart)"
  echo "6) $(tr_text menu_logs)"
  echo "7) $(tr_text menu_follow)"
  echo "8) $(tr_text menu_doctor)"
  echo "9) $(tr_text menu_language)"
  echo "10) $(tr_text menu_about)"
  echo "0) $(tr_text menu_exit)"
  echo
  read -r -p "$(tr_text prompt_choose): " choice

  case "$choice" in
    1) run_status ;;
    2) run_full ;;
    3) run_action start ;;
    4) run_action stop ;;
    5) run_action restart ;;
    6) run_logs logs ;;
    7) run_logs follow ;;
    8) run_doctor ;;
    9) choose_language ;;
    10) show_about ;;
    0) exit 0 ;;
    *) echo "$(tr_text wrong_choice)"; pause_screen ;;
  esac
done
